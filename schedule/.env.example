# --- app_config (DynamoDB) ---
APP_CONFIG_TABLE_NAME=app_config
APP_CONFIG_ITEM_ID=microservicio-schedule
APP_CONFIG_ITEM_PK=config_id

# --- AWS / DynamoDB ---
AWS_REGION=us-east-1
# Para DynamoDB local descomenta y ajusta:
# DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local

# --- Scheduler worker ---
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=30
LOCK_TIMEOUT_SECONDS=300

# --- HTTP a microservicios destino ---
# Usado solo si app_config no define request_timeout_seconds
DEFAULT_REQUEST_TIMEOUT_SECONDS=30

# --- Solo para exploracion/tests sin infra (no usar en prod) ---
# SKIP_BOOTSTRAP=false
