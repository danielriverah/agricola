# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=local
APP_BUILD_TAG=dev-local
APP_PORT=8004

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# Solo necesario en local; en producción usar IAM Role / credenciales del entorno
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Nombre exacto de la tabla DynamoDB con las producciones
DYNAMO_TABLE_PRODUCCIONES=producciones_monitoreo

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=agro_sentinel
MYSQL_USER=root
MYSQL_PASSWORD=tu_password

# ─── Open-Meteo ───────────────────────────────────────────────────────────────
# No modificar salvo cambio de región geográfica del proyecto
OPENMETEO_TIMEZONE=America/Mexico_City

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Si está en true, el servicio ejecuta el sync diariamente a la hora configurada
SCHEDULER_ENABLED=false
# Hora de ejecución en formato HH:MM (zona horaria configurada en SCHEDULER_TIMEZONE)
SCHEDULER_TIME=06:00
# Zona horaria usada por el scheduler independientemente de la del servidor
SCHEDULER_TIMEZONE=America/Mexico_City

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
