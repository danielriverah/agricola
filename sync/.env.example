# ============================================================================
# AgroSentinel Sync — .env
# Principio: el .env SOLO trae la conexion a DynamoDB y el identificador del
# item de configuracion. El resto (MySQL, S3, scheduler) vive en el item de
# config centralizada en DynamoDB y se lee en runtime.
# ============================================================================

# --- Meta ---
APP_ENV=local
APP_BUILD_TAG=dev
LOG_LEVEL=INFO
SERVICE_PORT=8006

# --- Conexion DynamoDB ---
AWS_REGION=us-east-1
DYNAMODB_USE_AWS=false
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000
AWS_ACCESS_KEY_ID_CUSTOM=local
AWS_SECRET_ACCESS_KEY_CUSTOM=local
AWS_SESSION_TOKEN_CUSTOM=

# --- Tablas base de Dynamo ---
PRODUCTION_MONITORING_TABLE_NAME=production_monitoring
PRODUCTION_MONITORING_DETAIL_TABLE_NAME=production_monitoring_detalle

# --- Item de configuracion centralizada ---
APP_CONFIG_TABLE_NAME=app_config
APP_CONFIG_ITEM_ID=microservicio-sync
APP_CONFIG_ITEM_PK=config_id
# APP_CONFIG_ITEM_SK=    # opcional, reservado para extensiones futuras

# ----------------------------------------------------------------------------
# Fallbacks opcionales (solo si el item de config de Dynamo no esta disponible
# y quieres arrancar de todas formas). En produccion, dejalos vacios.
# ----------------------------------------------------------------------------
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=agro_sentinel
# MYSQL_USER=
# MYSQL_PASSWORD=
# MONITORING_S3_BUCKET=sentinela-monitoring
